---
import Layout from "../../layouts/Layout.astro";
import TopBar from "../../components/TopBar.astro";
import { projectsContent } from "../../content/home";
---

<Layout>
  <TopBar />
  <main class="min-h-screen bg-background pt-32 pb-16 px-8 flex justify-center">
    <div class="max-w-7xl w-full">
      <header class="mb-16">
        <h1 class="text-4xl md:text-5xl font-headline font-bold text-on-surface mb-4">
          {projectsContent.title}
        </h1>
        <p class="text-lg text-on-surface-variant font-body">{projectsContent.subtitle}</p>
      </header>

      <!-- Card Container for Projects -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projectsContent.projects.map((project) => (
          <div
            class="group flex flex-col h-full bg-surface-container-low rounded-3xl p-8 hover:bg-surface-container transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-primary/5 border border-outline-variant/20"
          >
            <div class="grow">
              <h2 class="text-2xl font-headline font-bold text-on-surface mb-4">
                {project.title}
              </h2>
              <!-- Project Description -->
              <p class="text-on-surface-variant font-body leading-relaxed mb-6">
                {project.description}
              </p>
            </div>
            <div class="mt-auto pt-4 border-t border-outline-variant/30 flex justify-end">
              <a 
                href={project.github} 
                target="_blank" 
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-sm font-label font-bold text-on-primary-container bg-primary-container px-4 py-2 rounded-full hover:bg-primary hover:text-on-primary transition-colors focus:outline-none focus:ring-4 focus:ring-primary/20"
              >
                <span>GitHub</span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.02c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
                </svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>
</Layout>