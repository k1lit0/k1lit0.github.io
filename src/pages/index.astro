---
import Layout from "../layouts/Layout.astro";
import TopBar from "../components/TopBar.astro";
import Footer from "../components/Footer.astro";
import { heroContent, statsContent, guestbookContent } from "../content/home";
---

<Layout>
    <TopBar />
    <main class="px-8 mt-24 max-w-7xl space-y-32" >
      <section class="flex flex-col gap-32 items-center md:flex-row">
        <div class="space-y-8 basis-2/5">
          <div
            class="inline-block px-4 py-1 bg-secondary-container text-on-secondary-container rounded-full font-label text-xs tracking-widest uppercase"
          >
            {heroContent.tagline}
          </div>
          <h1
            class="font-headline text-5xl md:text-7xl font-extrabold leading-[1.1] text-primary tracking-tighter"
            set:html={heroContent.headline}
          />
          <div
            class="space-y-6 text-lg md:text-xl text-on-surface-variant max-w-lg italic leading-relaxed"
          >
            <p>
              {heroContent.descriptionEn}
            </p>
            <p class="font-normal not-italic opacity-80">
              {heroContent.descriptionZh}
            </p>
          </div>
        </div>
        <div class="relative basis-3/5">
          <div
            class="absolute -inset-4 bg-primary-container/20 rounded-xl -rotate-2 hover:rotate-0 transition-transform duration-500"
          >
          </div>
          <img
            alt={heroContent.imageAlt}
            class="relative rounded-xl w-full aspect-4/5 object-cover grayscale-20 brightness-105 shadow-2xl pointer-events-none"
            data-alt={heroContent.imageDataAlt}
            src={heroContent.imageUrl}
          />
        </div>
      </section>
      <section class="grid grid-cols-1 md:grid-cols-3 gap-12 items-start">
        <div class="space-y-4">
          <span
            class="font-label text-xs tracking-[0.2em] text-outline uppercase"
            >{statsContent.milestoneTag}</span
          >
          <div class="text-4xl font-headline font-bold text-primary">
            {statsContent.milestoneDate}
          </div>
          <p class="text-on-surface-variant leading-relaxed">
            {statsContent.milestoneDescEn}
          </p>
          <p class="text-sm opacity-60">
            {statsContent.milestoneDescZh}
          </p>
        </div>
        <div
          class="md:col-span-2 bg-surface-container-low rounded-xl p-12 relative overflow-hidden"
        >
          <div class="relative z-10 space-y-6">
            <h3 class="font-headline text-2xl font-bold">{statsContent.statsTitle}</h3>
            <div class="flex flex-wrap gap-8">
              {statsContent.stats.map((stat, i) => (
                <>
                  <div>
                    <div class="text-3xl font-headline font-bold">{stat.value}</div>
                    <div class="font-label text-xs text-outline">
                      {stat.label}
                    </div>
                  </div>
                  {i < statsContent.stats.length - 1 && (
                    <div class="w-px h-12 bg-outline-variant/30 hidden md:block" />
                  )}
                </>
              ))}
            </div>
          </div>
        </div>
      </section>
      <section class="space-y-12 pb-20">
        <div class="text-center space-y-4">
          <h2
            class="font-headline text-4xl font-extrabold text-secondary tracking-tight"
          >
            {guestbookContent.title}
          </h2>
          <p class="text-on-surface-variant italic">
            {guestbookContent.subtitle}
          </p>
        </div>
        <div class="flex flex-wrap justify-center gap-6 max-w-5xl mx-auto">
          {guestbookContent.messages.map(msg => (
            <div
              class={`${msg.bubbleBaseClass} bubble-float p-8 rounded-full max-w-sm border border-outline-variant/10 ${msg.containerMargin}`}
            >
              <p class={`text-on-surface leading-relaxed ${msg.isItalic ? 'italic' : ''}`}>
                {msg.text}
              </p>
              <div class="mt-4 flex items-center gap-3">
                <div class={`w-8 h-8 rounded-full ${msg.avatarClass}`}></div>
                <span class="font-label text-xs font-bold">{msg.author}</span>
              </div>
            </div>
          ))}
        </div>
      </section>
    </main>
    <Footer />
</Layout>
