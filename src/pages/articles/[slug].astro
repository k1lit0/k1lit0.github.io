---
import Layout from "../../layouts/Layout.astro";
import TopBar from "../../components/TopBar.astro";

// 定义文章数据类型
interface Frontmatter {
  title: string;
  date: string;
}
interface Post {
  file: string;
  frontmatter: Frontmatter;
  Content: any;
}

// 获取所有文章数据
export async function getStaticPaths() {
  const posts = Object.values(import.meta.glob('../../blog/*.md', { eager: true })) as Post[];
  
  return posts.map((post) => {
    // 提取文件名作为 slug
    const fileName = post.file.split(/[\\/]/).pop();
    const slug = fileName ? fileName.split('.')[0] : '';
    return {
      params: { slug },
      props: { post }  // 在文章页面内部渲染md内容
    };
  });
}

const { post } = Astro.props as { post: Post };
const { Content } = post; // 这是预先获取好的 md 组件
---

<Layout>
  <TopBar />
  <!-- 新路由页面渲染获取的 md 内容 -->
  <main class="min-h-screen bg-background pt-32 pb-16 px-8 flex justify-center">
    <article class="max-w-3xl w-full text-on-surface font-body [&>h1]:text-4xl [&>h1]:font-headline [&>h1]:font-bold [&>h1]:mb-6 [&>h1]:mt-8 [&>h2]:text-2xl [&>h2]:font-headline [&>h2]:font-bold [&>h2]:mb-4 [&>h2]:mt-8 [&>h3]:text-xl [&>h3]:font-headline [&>h3]:font-bold [&>h3]:mb-3 [&>h3]:mt-6 [&>p]:mb-6 [&>p]:leading-relaxed [&>p]:text-on-surface-variant [&>ul]:list-disc [&>ul]:pl-6 [&>ul]:mb-6 [&>ol]:list-decimal [&>ol]:pl-6 [&>ol]:mb-6 [&>pre]:p-4 [&>pre]:rounded-2xl [&>pre]:bg-surface-variant [&>pre]:overflow-x-auto [&>pre]:mb-6 [&>code]:bg-surface-variant [&>code]:px-1 [&>code]:rounded [&>code]:font-mono [&>code]:text-sm [&>blockquote]:border-l-4 [&>blockquote]:border-primary [&>blockquote]:pl-4 [&>blockquote]:italic [&>blockquote]:text-outline [&>a]:text-primary [&>a]:underline hover:[&>a]:text-primary-dim">
      <header class="mb-12 border-b border-surface-variant pb-8">
        <h1 class="text-4xl md:text-5xl font-bold font-headline mb-4 tracking-tight">{post.frontmatter.title}</h1>
        <div class="text-on-surface-variant font-label text-sm tracking-widest uppercase">
          {new Date(post.frontmatter.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
        </div>
      </header>
      
      <!-- 渲染 md 正文 -->
      <Content />
    </article>
  </main>
</Layout>