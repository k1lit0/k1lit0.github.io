---
import { siteConfig } from "../content/home";

const pathname = Astro.url.pathname;

const isActive = (href: string) => {
  if (href === "/") {
    return pathname === "/";
  }
  return pathname.startsWith(href);
};

---



<nav class="fixed top-0 w-full z-50 bg-[#f9faf4]/70 backdrop-blur-xl bg-linear-to-b from-stone-200/10 to-transparent">
  <div class="flex justify-between items-center px-8 py-4 max-w-7xl mx-auto">
    <div class="text-2xl font-['Plus_Jakarta_Sans'] font-bold text-stone-800 tracking-tight">
      {siteConfig.navTitle}
    </div>
    <div class="hidden md:flex items-center gap-8">
      {siteConfig.navLinks.map((link) => (
        <a
          class={`text-stone-500 hover:text-stone-800 transition-colors duration-300 font-['Plus_Jakarta_Sans'] font-bold tracking-tight ${isActive(link.href) ? 'text-lime-700 border-b-2 border-lime-500/30 pb-1' : ''}`}
          href={link.href}
        >
          {link.text}
        </a>
      ))}
    </div>
    <div class="flex items-center gap-4">
      <button class="p-2 hover:bg-stone-100/50 rounded-full transition-all active:opacity-80 scale-95">
        <span class="material-symbols-outlined text-lime-600">contrast</span>
      </button>
    </div>
  </div>
</nav>